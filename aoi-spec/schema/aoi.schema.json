{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoi.dev/schemas/0.1.0/aoi.schema.json",
  "title": "AOI v0.1",
  "description": "Analysis Operation Interface v0.1 canonical schema.",
  "oneOf": [
    { "$ref": "#/$defs/requests/ObserveRequest" },
    { "$ref": "#/$defs/requests/CompareRequest" },
    { "$ref": "#/$defs/requests/DecomposeRequest" },
    { "$ref": "#/$defs/requests/CorrelateRequest" },
    { "$ref": "#/$defs/requests/DetectRequest" },
    { "$ref": "#/$defs/requests/TestRequest" },
    { "$ref": "#/$defs/requests/ForecastRequest" },
    { "$ref": "#/$defs/artifacts/Artifact" },
    { "$ref": "#/$defs/capability/CapabilityDeclaration" }
  ],
  "$defs": {
    "primitives": {
      "IntentName": {
        "type": "string",
        "enum": [
          "observe",
          "compare",
          "decompose",
          "correlate",
          "detect",
          "test",
          "forecast"
        ]
      },
      "ArtifactType": {
        "type": "string",
        "enum": [
          "scalar_observation",
          "time_series_observation",
          "segmented_observation",
          "scalar_delta",
          "time_series_delta",
          "segmented_delta",
          "delta_decomposition",
          "anomaly_candidates",
          "association_result",
          "hypothesis_test_result",
          "forecast_series"
        ]
      },
      "ISO8601": {
        "type": "string",
        "format": "date-time"
      },
      "Predicate": {
        "type": "object",
        "additionalProperties": false,
        "required": ["dialects"],
        "properties": {
          "dialects": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["expression"],
              "properties": {
                "dialect": {
                  "type": "string",
                  "default": "ANSI_SQL"
                },
                "expression": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      },
      "TimeScope": {
        "type": "object",
        "additionalProperties": false,
        "required": ["start", "end"],
        "properties": {
          "start": { "$ref": "#/$defs/primitives/ISO8601" },
          "end": { "$ref": "#/$defs/primitives/ISO8601" }
        }
      },
      "TimeGranularity": {
        "type": "string",
        "enum": ["hour", "day", "week", "month", "quarter", "year"]
      },
      "CompareType": {
        "type": "string",
        "default": "normal",
        "enum": [
          "normal",
          "yoy",
          "mom",
          "wow",
          "holiday_aligned_yoy",
          "weekday_aligned_yoy",
          "weekday_aligned_mon"
        ]
      },
      "ArtifactRef": {
        "type": "object",
        "additionalProperties": false,
        "required": ["step_type", "step_id", "artifact_id", "artifact_subtype"],
        "properties": {
          "step_type": { "$ref": "#/$defs/primitives/IntentName" },
          "step_id": { "type": "string", "minLength": 1 },
          "artifact_id": { "type": "string", "minLength": 1 },
          "artifact_subtype": { "$ref": "#/$defs/primitives/ArtifactType" }
        }
      },
      "ArtifactItemRef": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifact_ref", "item_id"],
        "properties": {
          "artifact_ref": { "$ref": "#/$defs/primitives/ArtifactRef" },
          "item_id": { "type": "string", "minLength": 1 }
        }
      },
      "StepRef": {
        "type": "object",
        "additionalProperties": false,
        "required": ["step_type", "step_id"],
        "properties": {
          "step_type": { "$ref": "#/$defs/primitives/IntentName" },
          "step_id": { "type": "string", "minLength": 1 }
        }
      },
      "AnalysisFailure": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "message", "details"],
        "properties": {
          "code": { "type": "string", "minLength": 1 },
          "message": { "type": "string", "minLength": 1 },
          "details": {
            "anyOf": [
              { "type": "object", "additionalProperties": true },
              { "type": "null" }
            ]
          }
        }
      },
      "HypothesisContract": {
        "type": "object",
        "additionalProperties": false,
        "required": ["family", "alternative", "alpha", "label"],
        "properties": {
          "family": { "type": "string", "minLength": 1 },
          "alternative": {
            "type": "string",
            "enum": ["two_sided", "greater", "less"]
          },
          "alpha": {
            "type": "number",
            "exclusiveMinimum": 0,
            "exclusiveMaximum": 1
          },
          "label": {
            "anyOf": [
              { "type": "string" },
              { "type": "null" }
            ]
          }
        }
      },
      "Slice": {
        "type": "object",
        "additionalProperties": false,
        "required": ["time_scope", "filter"],
        "properties": {
          "time_scope": { "$ref": "#/$defs/primitives/TimeScope" },
          "filter": {
            "anyOf": [
              { "$ref": "#/$defs/primitives/Predicate" },
              { "type": "null" }
            ]
          }
        }
      },
      "NumberOrNull": {
        "anyOf": [
          { "type": "number" },
          { "type": "null" }
        ]
      },
      "StringMap": {
        "type": "object",
        "additionalProperties": { "type": "string" }
      }
    },
    "requests": {
      "SpecVersion": {
        "type": "string",
        "const": "0.1.0"
      },
      "ObserveRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["intent", "metric", "time_scope", "filter"],
        "properties": {
          "spec_version": { "$ref": "#/$defs/requests/SpecVersion" },
          "intent": { "const": "observe" },
          "metric": { "type": "string", "minLength": 1 },
          "time_scope": { "$ref": "#/$defs/primitives/TimeScope" },
          "filter": {
            "anyOf": [
              { "$ref": "#/$defs/primitives/Predicate" },
              { "type": "null" }
            ]
          },
          "granularity": {
            "anyOf": [
              { "$ref": "#/$defs/primitives/TimeGranularity" },
              { "type": "null" }
            ]
          },
          "dimensions": {
            "anyOf": [
              {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              },
              { "type": "null" }
            ]
          }
        },
        "oneOf": [
          {
            "not": {
              "anyOf": [
                { "required": ["granularity"] },
                { "required": ["dimensions"] }
              ]
            }
          },
          {
            "properties": {
              "granularity": { "$ref": "#/$defs/primitives/TimeGranularity" }
            },
            "not": {
              "properties": {
                "dimensions": {
                  "type": "array"
                }
              },
              "required": ["dimensions"]
            },
            "required": ["granularity"]
          },
          {
            "properties": {
              "dimensions": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              }
            },
            "not": {
              "properties": {
                "granularity": {
                  "$ref": "#/$defs/primitives/TimeGranularity"
                }
              },
              "required": ["granularity"]
            },
            "required": ["dimensions"]
          },
          {
            "properties": {
              "granularity": { "type": "null" },
              "dimensions": { "type": "null" }
            },
            "required": ["granularity", "dimensions"]
          }
        ]
      },
      "CompareRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["intent", "left_ref", "right_ref"],
        "properties": {
          "spec_version": { "$ref": "#/$defs/requests/SpecVersion" },
          "intent": { "const": "compare" },
          "left_ref": { "$ref": "#/$defs/primitives/ArtifactRef" },
          "right_ref": { "$ref": "#/$defs/primitives/ArtifactRef" },
          "compare_type": { "$ref": "#/$defs/primitives/CompareType" }
        }
      },
      "DecomposeRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["intent", "compare_ref", "dimension"],
        "properties": {
          "spec_version": { "$ref": "#/$defs/requests/SpecVersion" },
          "intent": { "const": "decompose" },
          "compare_ref": { "$ref": "#/$defs/primitives/ArtifactRef" },
          "dimension": { "type": "string", "minLength": 1 },
          "limit": { "type": "integer", "minimum": 1 }
        }
      },
      "CorrelateRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["intent", "left_ref", "right_ref"],
        "properties": {
          "spec_version": { "$ref": "#/$defs/requests/SpecVersion" },
          "intent": { "const": "correlate" },
          "left_ref": { "$ref": "#/$defs/primitives/ArtifactRef" },
          "right_ref": { "$ref": "#/$defs/primitives/ArtifactRef" },
          "method": {
            "type": "string",
            "enum": ["pearson", "spearman"]
          }
        }
      },
      "DetectRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["intent", "metric", "time_scope", "granularity", "filter"],
        "properties": {
          "spec_version": { "$ref": "#/$defs/requests/SpecVersion" },
          "intent": { "const": "detect" },
          "metric": { "type": "string", "minLength": 1 },
          "time_scope": { "$ref": "#/$defs/primitives/TimeScope" },
          "granularity": { "$ref": "#/$defs/primitives/TimeGranularity" },
          "filter": {
            "anyOf": [
              { "$ref": "#/$defs/primitives/Predicate" },
              { "type": "null" }
            ]
          },
          "split_by": {
            "anyOf": [
              {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              { "type": "null" }
            ]
          },
          "profile": {
            "anyOf": [
              { "type": "string" },
              { "type": "null" }
            ]
          },
          "sensitivity": {
            "anyOf": [
              {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              { "type": "null" }
            ]
          },
          "limit": { "type": "integer", "minimum": 1 }
        }
      },
      "TestRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["intent", "metric", "left", "right", "kind", "hypothesis"],
        "properties": {
          "spec_version": { "$ref": "#/$defs/requests/SpecVersion" },
          "intent": { "const": "test" },
          "metric": { "type": "string", "minLength": 1 },
          "left": { "$ref": "#/$defs/primitives/Slice" },
          "right": { "$ref": "#/$defs/primitives/Slice" },
          "kind": {
            "type": "string",
            "enum": ["numeric", "rate"]
          },
          "hypothesis": { "$ref": "#/$defs/primitives/HypothesisContract" }
        }
      },
      "ForecastRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["intent", "source_ref", "horizon"],
        "properties": {
          "spec_version": { "$ref": "#/$defs/requests/SpecVersion" },
          "intent": { "const": "forecast" },
          "source_ref": { "$ref": "#/$defs/primitives/ArtifactRef" },
          "horizon": { "type": "integer", "minimum": 1 },
          "profile": {
            "anyOf": [
              { "type": "string" },
              { "type": "null" }
            ]
          }
        }
      }
    },
    "artifacts": {
      "Artifact": {
        "oneOf": [
          { "$ref": "#/$defs/artifacts/ScalarObservationArtifact" },
          { "$ref": "#/$defs/artifacts/TimeSeriesObservationArtifact" },
          { "$ref": "#/$defs/artifacts/SegmentedObservationArtifact" },
          { "$ref": "#/$defs/artifacts/ScalarDeltaArtifact" },
          { "$ref": "#/$defs/artifacts/TimeSeriesDeltaArtifact" },
          { "$ref": "#/$defs/artifacts/SegmentedDeltaArtifact" },
          { "$ref": "#/$defs/artifacts/DeltaDecompositionArtifact" },
          { "$ref": "#/$defs/artifacts/AnomalyCandidatesArtifact" },
          { "$ref": "#/$defs/artifacts/AssociationResultArtifact" },
          { "$ref": "#/$defs/artifacts/HypothesisTestResultArtifact" },
          { "$ref": "#/$defs/artifacts/ForecastSeriesArtifact" }
        ]
      },
      "ObservationSubject": {
        "type": "object",
        "additionalProperties": false,
        "required": ["metric", "time_scope", "filter", "granularity", "dimensions"],
        "properties": {
          "metric": { "type": "string", "minLength": 1 },
          "time_scope": { "$ref": "#/$defs/primitives/TimeScope" },
          "filter": {
            "anyOf": [
              { "$ref": "#/$defs/primitives/Predicate" },
              { "type": "null" }
            ]
          },
          "granularity": {
            "anyOf": [
              { "$ref": "#/$defs/primitives/TimeGranularity" },
              { "type": "null" }
            ]
          },
          "dimensions": {
            "anyOf": [
              {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              },
              { "type": "null" }
            ]
          }
        }
      },
      "DeltaSubject": {
        "type": "object",
        "additionalProperties": false,
        "required": ["left_ref", "right_ref", "compare_type"],
        "properties": {
          "left_ref": { "$ref": "#/$defs/primitives/ArtifactRef" },
          "right_ref": { "$ref": "#/$defs/primitives/ArtifactRef" },
          "compare_type": { "$ref": "#/$defs/primitives/CompareType" }
        }
      },
      "ScalarObservationArtifact": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifact_type", "artifact_id", "produced_by", "subject"],
        "properties": {
          "artifact_type": { "const": "scalar_observation" },
          "artifact_id": { "type": "string", "minLength": 1 },
          "produced_by": { "$ref": "#/$defs/primitives/StepRef" },
          "subject": { "$ref": "#/$defs/artifacts/ObservationSubject" },
          "result": {
            "type": "object",
            "additionalProperties": false,
            "required": ["value"],
            "properties": {
              "value": { "$ref": "#/$defs/primitives/NumberOrNull" }
            }
          },
          "failure": { "$ref": "#/$defs/primitives/AnalysisFailure" }
        },
        "oneOf": [
          { "required": ["result"], "not": { "required": ["failure"] } },
          { "required": ["failure"], "not": { "required": ["result"] } }
        ]
      },
      "TimeSeriesObservationArtifact": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifact_type", "artifact_id", "produced_by", "subject"],
        "properties": {
          "artifact_type": { "const": "time_series_observation" },
          "artifact_id": { "type": "string", "minLength": 1 },
          "produced_by": { "$ref": "#/$defs/primitives/StepRef" },
          "subject": { "$ref": "#/$defs/artifacts/ObservationSubject" },
          "result": {
            "type": "object",
            "additionalProperties": false,
            "required": ["points"],
            "properties": {
              "points": {
                "type": "array",
                "items": { "$ref": "#/$defs/artifacts/TimeSeriesPoint" }
              }
            }
          },
          "failure": { "$ref": "#/$defs/primitives/AnalysisFailure" }
        },
        "oneOf": [
          { "required": ["result"], "not": { "required": ["failure"] } },
          { "required": ["failure"], "not": { "required": ["result"] } }
        ]
      },
      "SegmentedObservationArtifact": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifact_type", "artifact_id", "produced_by", "subject"],
        "properties": {
          "artifact_type": { "const": "segmented_observation" },
          "artifact_id": { "type": "string", "minLength": 1 },
          "produced_by": { "$ref": "#/$defs/primitives/StepRef" },
          "subject": { "$ref": "#/$defs/artifacts/ObservationSubject" },
          "result": {
            "type": "object",
            "additionalProperties": false,
            "required": ["rows"],
            "properties": {
              "rows": {
                "type": "array",
                "items": { "$ref": "#/$defs/artifacts/SegmentedObservationRow" }
              }
            }
          },
          "failure": { "$ref": "#/$defs/primitives/AnalysisFailure" }
        },
        "oneOf": [
          { "required": ["result"], "not": { "required": ["failure"] } },
          { "required": ["failure"], "not": { "required": ["result"] } }
        ]
      },
      "TimeSeriesPoint": {
        "type": "object",
        "additionalProperties": false,
        "required": ["bucket_start", "value"],
        "properties": {
          "bucket_start": { "$ref": "#/$defs/primitives/ISO8601" },
          "value": { "$ref": "#/$defs/primitives/NumberOrNull" }
        }
      },
      "SegmentedObservationRow": {
        "type": "object",
        "additionalProperties": false,
        "required": ["item_id", "keys", "value"],
        "properties": {
          "item_id": { "type": "string", "minLength": 1 },
          "keys": { "$ref": "#/$defs/primitives/StringMap" },
          "value": { "$ref": "#/$defs/primitives/NumberOrNull" }
        }
      },
      "ScalarDeltaArtifact": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifact_type", "artifact_id", "produced_by", "subject"],
        "properties": {
          "artifact_type": { "const": "scalar_delta" },
          "artifact_id": { "type": "string", "minLength": 1 },
          "produced_by": { "$ref": "#/$defs/primitives/StepRef" },
          "subject": { "$ref": "#/$defs/artifacts/DeltaSubject" },
          "result": { "$ref": "#/$defs/artifacts/ScalarDeltaResult" },
          "failure": { "$ref": "#/$defs/primitives/AnalysisFailure" }
        },
        "oneOf": [
          { "required": ["result"], "not": { "required": ["failure"] } },
          { "required": ["failure"], "not": { "required": ["result"] } }
        ]
      },
      "TimeSeriesDeltaArtifact": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifact_type", "artifact_id", "produced_by", "subject"],
        "properties": {
          "artifact_type": { "const": "time_series_delta" },
          "artifact_id": { "type": "string", "minLength": 1 },
          "produced_by": { "$ref": "#/$defs/primitives/StepRef" },
          "subject": { "$ref": "#/$defs/artifacts/DeltaSubject" },
          "result": {
            "type": "object",
            "additionalProperties": false,
            "required": ["points", "matched_time_scope"],
            "properties": {
              "points": {
                "type": "array",
                "items": { "$ref": "#/$defs/artifacts/DeltaPoint" }
              },
              "matched_time_scope": {
                "anyOf": [
                  { "$ref": "#/$defs/primitives/TimeScope" },
                  { "type": "null" }
                ]
              }
            }
          },
          "failure": { "$ref": "#/$defs/primitives/AnalysisFailure" }
        },
        "oneOf": [
          { "required": ["result"], "not": { "required": ["failure"] } },
          { "required": ["failure"], "not": { "required": ["result"] } }
        ]
      },
      "SegmentedDeltaArtifact": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifact_type", "artifact_id", "produced_by", "subject"],
        "properties": {
          "artifact_type": { "const": "segmented_delta" },
          "artifact_id": { "type": "string", "minLength": 1 },
          "produced_by": { "$ref": "#/$defs/primitives/StepRef" },
          "subject": { "$ref": "#/$defs/artifacts/DeltaSubject" },
          "result": {
            "type": "object",
            "additionalProperties": false,
            "required": ["rows", "matched_time_scope"],
            "properties": {
              "rows": {
                "type": "array",
                "items": { "$ref": "#/$defs/artifacts/SegmentedDeltaRow" }
              },
              "matched_time_scope": {
                "anyOf": [
                  { "$ref": "#/$defs/primitives/TimeScope" },
                  { "type": "null" }
                ]
              }
            }
          },
          "failure": { "$ref": "#/$defs/primitives/AnalysisFailure" }
        },
        "oneOf": [
          { "required": ["result"], "not": { "required": ["failure"] } },
          { "required": ["failure"], "not": { "required": ["result"] } }
        ]
      },
      "ScalarDeltaResult": {
        "type": "object",
        "additionalProperties": false,
        "required": ["left_value", "right_value", "delta", "matched_time_scope"],
        "properties": {
          "left_value": { "$ref": "#/$defs/primitives/NumberOrNull" },
          "right_value": { "$ref": "#/$defs/primitives/NumberOrNull" },
          "delta": { "$ref": "#/$defs/primitives/NumberOrNull" },
          "matched_time_scope": {
            "anyOf": [
              { "$ref": "#/$defs/primitives/TimeScope" },
              { "type": "null" }
            ]
          }
        }
      },
      "DeltaPoint": {
        "type": "object",
        "additionalProperties": false,
        "required": ["bucket_start", "left_value", "right_value", "delta"],
        "properties": {
          "bucket_start": { "$ref": "#/$defs/primitives/ISO8601" },
          "left_value": { "$ref": "#/$defs/primitives/NumberOrNull" },
          "right_value": { "$ref": "#/$defs/primitives/NumberOrNull" },
          "delta": { "$ref": "#/$defs/primitives/NumberOrNull" }
        }
      },
      "SegmentedDeltaRow": {
        "type": "object",
        "additionalProperties": false,
        "required": ["item_id", "keys", "left_value", "right_value", "delta"],
        "properties": {
          "item_id": { "type": "string", "minLength": 1 },
          "keys": { "$ref": "#/$defs/primitives/StringMap" },
          "left_value": { "$ref": "#/$defs/primitives/NumberOrNull" },
          "right_value": { "$ref": "#/$defs/primitives/NumberOrNull" },
          "delta": { "$ref": "#/$defs/primitives/NumberOrNull" }
        }
      },
      "DeltaDecompositionArtifact": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifact_type", "artifact_id", "produced_by", "subject"],
        "properties": {
          "artifact_type": { "const": "delta_decomposition" },
          "artifact_id": { "type": "string", "minLength": 1 },
          "produced_by": { "$ref": "#/$defs/primitives/StepRef" },
          "subject": {
            "type": "object",
            "additionalProperties": false,
            "required": ["compare_ref", "dimension"],
            "properties": {
              "compare_ref": { "$ref": "#/$defs/primitives/ArtifactRef" },
              "dimension": { "type": "string", "minLength": 1 }
            }
          },
          "result": {
            "type": "object",
            "additionalProperties": false,
            "required": ["items"],
            "properties": {
              "items": {
                "type": "array",
                "items": { "$ref": "#/$defs/artifacts/DecompositionItem" }
              }
            }
          },
          "failure": { "$ref": "#/$defs/primitives/AnalysisFailure" }
        },
        "oneOf": [
          { "required": ["result"], "not": { "required": ["failure"] } },
          { "required": ["failure"], "not": { "required": ["result"] } }
        ]
      },
      "DecompositionItem": {
        "type": "object",
        "additionalProperties": false,
        "required": ["item_id", "key", "contribution", "share"],
        "properties": {
          "item_id": { "type": "string", "minLength": 1 },
          "key": {
            "anyOf": [
              { "type": "string" },
              { "type": "number" },
              { "type": "boolean" },
              { "type": "null" }
            ]
          },
          "contribution": { "type": "number" },
          "share": { "type": "number" }
        }
      },
      "AnomalyCandidatesArtifact": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifact_type", "artifact_id", "produced_by", "subject"],
        "properties": {
          "artifact_type": { "const": "anomaly_candidates" },
          "artifact_id": { "type": "string", "minLength": 1 },
          "produced_by": { "$ref": "#/$defs/primitives/StepRef" },
          "subject": {
            "type": "object",
            "additionalProperties": false,
            "required": ["metric", "time_scope", "filter", "granularity", "split_by", "profile", "sensitivity"],
            "properties": {
              "metric": { "type": "string", "minLength": 1 },
              "time_scope": { "$ref": "#/$defs/primitives/TimeScope" },
              "filter": {
                "anyOf": [
                  { "$ref": "#/$defs/primitives/Predicate" },
                  { "type": "null" }
                ]
              },
              "granularity": { "$ref": "#/$defs/primitives/TimeGranularity" },
              "split_by": {
                "anyOf": [
                  {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 }
                  },
                  { "type": "null" }
                ]
              },
              "profile": {
                "anyOf": [
                  { "type": "string" },
                  { "type": "null" }
                ]
              },
              "sensitivity": {
                "anyOf": [
                  { "type": "number" },
                  { "type": "null" }
                ]
              }
            }
          },
          "result": {
            "type": "object",
            "additionalProperties": false,
            "required": ["items"],
            "properties": {
              "items": {
                "type": "array",
                "items": { "$ref": "#/$defs/artifacts/AnomalyCandidate" }
              }
            }
          },
          "failure": { "$ref": "#/$defs/primitives/AnalysisFailure" }
        },
        "oneOf": [
          { "required": ["result"], "not": { "required": ["failure"] } },
          { "required": ["failure"], "not": { "required": ["result"] } }
        ]
      },
      "AnomalyCandidate": {
        "type": "object",
        "additionalProperties": false,
        "required": ["item_id", "bucket_start", "value", "score", "series_keys"],
        "properties": {
          "item_id": { "type": "string", "minLength": 1 },
          "bucket_start": { "$ref": "#/$defs/primitives/ISO8601" },
          "value": { "type": "number" },
          "score": { "type": "number" },
          "series_keys": {
            "anyOf": [
              { "$ref": "#/$defs/primitives/StringMap" },
              { "type": "null" }
            ]
          }
        }
      },
      "AssociationResultArtifact": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifact_type", "artifact_id", "produced_by", "subject"],
        "properties": {
          "artifact_type": { "const": "association_result" },
          "artifact_id": { "type": "string", "minLength": 1 },
          "produced_by": { "$ref": "#/$defs/primitives/StepRef" },
          "subject": {
            "type": "object",
            "additionalProperties": false,
            "required": ["left_ref", "right_ref", "method"],
            "properties": {
              "left_ref": { "$ref": "#/$defs/primitives/ArtifactRef" },
              "right_ref": { "$ref": "#/$defs/primitives/ArtifactRef" },
              "method": {
                "anyOf": [
                  { "type": "string", "enum": ["pearson", "spearman"] },
                  { "type": "null" }
                ]
              }
            }
          },
          "result": {
            "type": "object",
            "additionalProperties": false,
            "required": ["coefficient", "p_value", "n_pairs", "matched_time_scope"],
            "properties": {
              "coefficient": { "type": "number" },
              "p_value": { "$ref": "#/$defs/primitives/NumberOrNull" },
              "n_pairs": { "type": "integer", "minimum": 0 },
              "matched_time_scope": {
                "anyOf": [
                  { "$ref": "#/$defs/primitives/TimeScope" },
                  { "type": "null" }
                ]
              }
            }
          },
          "failure": { "$ref": "#/$defs/primitives/AnalysisFailure" }
        },
        "oneOf": [
          { "required": ["result"], "not": { "required": ["failure"] } },
          { "required": ["failure"], "not": { "required": ["result"] } }
        ]
      },
      "HypothesisTestResultArtifact": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifact_type", "artifact_id", "produced_by", "subject"],
        "properties": {
          "artifact_type": { "const": "hypothesis_test_result" },
          "artifact_id": { "type": "string", "minLength": 1 },
          "produced_by": { "$ref": "#/$defs/primitives/StepRef" },
          "subject": {
            "type": "object",
            "additionalProperties": false,
            "required": ["metric", "left", "right", "kind", "hypothesis"],
            "properties": {
              "metric": { "type": "string", "minLength": 1 },
              "left": { "$ref": "#/$defs/primitives/Slice" },
              "right": { "$ref": "#/$defs/primitives/Slice" },
              "kind": { "type": "string", "enum": ["numeric", "rate"] },
              "hypothesis": { "$ref": "#/$defs/primitives/HypothesisContract" }
            }
          },
          "result": {
            "type": "object",
            "additionalProperties": false,
            "required": ["statistic", "p_value", "decision", "assumption_notes"],
            "properties": {
              "statistic": { "type": "number" },
              "p_value": { "type": "number" },
              "decision": {
                "type": "object",
                "additionalProperties": false,
                "required": ["reject_null"],
                "properties": {
                  "reject_null": {
                    "anyOf": [
                      { "type": "boolean" },
                      { "type": "null" }
                    ]
                  }
                }
              },
              "assumption_notes": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          },
          "failure": { "$ref": "#/$defs/primitives/AnalysisFailure" }
        },
        "oneOf": [
          { "required": ["result"], "not": { "required": ["failure"] } },
          { "required": ["failure"], "not": { "required": ["result"] } }
        ]
      },
      "ForecastSeriesArtifact": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifact_type", "artifact_id", "produced_by", "subject"],
        "properties": {
          "artifact_type": { "const": "forecast_series" },
          "artifact_id": { "type": "string", "minLength": 1 },
          "produced_by": { "$ref": "#/$defs/primitives/StepRef" },
          "subject": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source_ref", "horizon", "profile"],
            "properties": {
              "source_ref": { "$ref": "#/$defs/primitives/ArtifactRef" },
              "horizon": { "type": "integer", "minimum": 1 },
              "profile": {
                "anyOf": [
                  { "type": "string" },
                  { "type": "null" }
                ]
              }
            }
          },
          "result": {
            "type": "object",
            "additionalProperties": false,
            "required": ["points"],
            "properties": {
              "points": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["bucket_start", "value", "ci_low", "ci_high"],
                  "properties": {
                    "bucket_start": { "$ref": "#/$defs/primitives/ISO8601" },
                    "value": { "type": "number" },
                    "ci_low": { "$ref": "#/$defs/primitives/NumberOrNull" },
                    "ci_high": { "$ref": "#/$defs/primitives/NumberOrNull" }
                  }
                }
              }
            }
          },
          "failure": { "$ref": "#/$defs/primitives/AnalysisFailure" }
        },
        "oneOf": [
          { "required": ["result"], "not": { "required": ["failure"] } },
          { "required": ["failure"], "not": { "required": ["result"] } }
        ]
      }
    },
    "capability": {
      "CapabilityDeclaration": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "spec_version",
          "supported_intents",
          "supported_predicate_dialects",
          "supported_compare_types",
          "supported_artifact_types"
        ],
        "properties": {
          "spec_version": { "const": "0.1.0" },
          "supported_intents": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/primitives/IntentName" }
          },
          "supported_predicate_dialects": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "supported_compare_types": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/primitives/CompareType" }
          },
          "supported_artifact_types": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/primitives/ArtifactType" }
          }
        }
      }
    }
  }
}
