{
  "version": "0.2.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoi.dev/schemas/0.2.0/aoi.schema.json",
  "title": "AOI v0.2",
  "description": "Analysis Operation Interface v0.2 canonical schema.",
  "oneOf": [
    {
      "$ref": "#/$defs/requests/observe"
    },
    {
      "$ref": "#/$defs/requests/compare"
    },
    {
      "$ref": "#/$defs/requests/decompose"
    },
    {
      "$ref": "#/$defs/requests/correlate"
    },
    {
      "$ref": "#/$defs/requests/detect"
    },
    {
      "$ref": "#/$defs/requests/test"
    },
    {
      "$ref": "#/$defs/requests/forecast"
    },
    {
      "$ref": "#/$defs/derived_requests/validate"
    },
    {
      "$ref": "#/$defs/derived_requests/attribute"
    },
    {
      "$ref": "#/$defs/derived_requests/diagnose"
    },
    {
      "$ref": "#/$defs/artifacts/Artifact"
    },
    {
      "$ref": "#/$defs/artifacts/MetricFrameArtifact"
    },
    {
      "$ref": "#/$defs/artifacts/DeltaFrameArtifact"
    }
  ],
  "$defs": {
    "primitives": {
      "ISO8601": {
        "type": "string",
        "format": "date-time"
      },
      "TimeScope": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "field",
          "start",
          "end"
        ],
        "properties": {
          "field": {
            "type": "string",
            "minLength": 1
          },
          "start": {
            "$ref": "#/$defs/primitives/ISO8601"
          },
          "end": {
            "$ref": "#/$defs/primitives/ISO8601"
          }
        }
      },
      "TimeGranularity": {
        "type": "string",
        "enum": [
          "hour",
          "day",
          "week",
          "month",
          "quarter",
          "year"
        ]
      },
      "CompareType": {
        "type": "string",
        "default": "normal",
        "enum": [
          "normal",
          "holiday_aligned",
          "weekday_aligned",
          "holiday_and_weekday_aligned"
        ]
      },
      "HypothesisFamily": {
        "type": "string",
        "enum": [
          "two_sample_mean"
        ]
      },
      "HypothesisAlternative": {
        "type": "string",
        "enum": [
          "two_sided",
          "greater",
          "less"
        ]
      },
      "HypothesisSignificance": {
        "type": "string",
        "enum": [
          "conservative",
          "balanced",
          "aggressive"
        ]
      },
      "TestKind": {
        "type": "string",
        "enum": [
          "numeric"
        ]
      },
      "CorrelationMethod": {
        "type": "string",
        "enum": [
          "pearson",
          "spearman"
        ]
      },
      "AnalysisFailure": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string",
            "minLength": 1
          },
          "message": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "Slice": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "time_scope"
        ],
        "properties": {
          "time_scope": {
            "$ref": "#/$defs/primitives/TimeScope"
          },
          "filter": {
            "$ref": "#/$defs/primitives/Expression"
          }
        }
      },
      "NumberOrNull": {
        "anyOf": [
          {
            "type": "number"
          },
          {
            "type": "null"
          }
        ]
      },
      "Expression": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "dialects"
        ],
        "properties": {
          "dialects": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "expression"
              ],
              "properties": {
                "dialect": {
                  "type": "string",
                  "default": "ANSI_SQL"
                },
                "expression": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      },
      "Hypothesis": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "family",
          "alternative",
          "significance"
        ],
        "properties": {
          "family": {
            "$ref": "#/$defs/primitives/HypothesisFamily"
          },
          "alternative": {
            "$ref": "#/$defs/primitives/HypothesisAlternative"
          },
          "significance": {
            "$ref": "#/$defs/primitives/HypothesisSignificance"
          }
        }
      },
      "DimensionKeyMap": {
        "type": "object",
        "additionalProperties": {
          "type": "string"
        },
        "required": []
      }
    },
    "requests": {
      "observe": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "metric",
          "time_scope"
        ],
        "properties": {
          "metric": {
            "type": "string",
            "minLength": 1
          },
          "time_scope": {
            "$ref": "#/$defs/primitives/TimeScope"
          },
          "filter": {
            "$ref": "#/$defs/primitives/Expression"
          },
          "granularity": {
            "$ref": "#/$defs/primitives/TimeGranularity"
          },
          "dimensions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      },
      "compare": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "current_artifact_id",
          "baseline_artifact_id"
        ],
        "properties": {
          "compare_type": {
            "$ref": "#/$defs/primitives/CompareType"
          },
          "current_artifact_id": {
            "type": "string",
            "minLength": 1
          },
          "baseline_artifact_id": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "decompose": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "compare_artifact_id",
          "dimension"
        ],
        "properties": {
          "dimension": {
            "type": "string",
            "minLength": 1
          },
          "limit": {
            "type": "integer",
            "minimum": 1
          },
          "compare_artifact_id": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "correlate": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "left_artifact_id",
          "right_artifact_id"
        ],
        "properties": {
          "method": {
            "$ref": "#/$defs/primitives/CorrelationMethod"
          },
          "left_artifact_id": {
            "type": "string",
            "minLength": 1
          },
          "right_artifact_id": {
            "type": "string",
            "minLength": 1
          },
          "min_pairs": {
            "type": "integer",
            "minimum": 1
          }
        }
      },
      "detect": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "metric",
          "time_scope",
          "granularity",
          "strategy"
        ],
        "properties": {
          "metric": {
            "type": "string",
            "minLength": 1
          },
          "time_scope": {
            "$ref": "#/$defs/primitives/TimeScope"
          },
          "granularity": {
            "$ref": "#/$defs/primitives/TimeGranularity"
          },
          "filter": {
            "$ref": "#/$defs/primitives/Expression"
          },
          "dimension": {
            "type": "string",
            "minLength": 1
          },
          "strategy": {
            "type": "string",
            "enum": [
              "point_anomaly",
              "period_shift"
            ]
          },
          "sensitivity": {
            "type": "string",
            "default": "aggressive",
            "enum": [
              "conservative",
              "balanced",
              "aggressive"
            ]
          },
          "limit": {
            "type": "integer",
            "minimum": 1
          }
        }
      },
      "test": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "metric",
          "current",
          "baseline",
          "grain",
          "kind",
          "hypothesis"
        ],
        "properties": {
          "metric": {
            "type": "string",
            "minLength": 1
          },
          "current": {
            "$ref": "#/$defs/primitives/Slice"
          },
          "baseline": {
            "$ref": "#/$defs/primitives/Slice"
          },
          "grain": {
            "$ref": "#/$defs/primitives/TimeGranularity"
          },
          "kind": {
            "$ref": "#/$defs/primitives/TestKind"
          },
          "hypothesis": {
            "$ref": "#/$defs/primitives/Hypothesis"
          }
        }
      },
      "forecast": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_artifact_id",
          "horizon"
        ],
        "properties": {
          "horizon": {
            "type": "integer",
            "minimum": 1
          },
          "source_artifact_id": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "derived_requests": {
      "validate": {
        "title": "Validate",
        "type": "object",
        "additionalProperties": false,
        "required": [
          "metric",
          "current",
          "baseline",
          "grain",
          "hypothesis"
        ],
        "properties": {
          "metric": {
            "type": "string",
            "minLength": 1
          },
          "current": {
            "$ref": "#/$defs/primitives/Slice"
          },
          "baseline": {
            "$ref": "#/$defs/primitives/Slice"
          },
          "grain": {
            "$ref": "#/$defs/primitives/TimeGranularity"
          },
          "hypothesis": {
            "$ref": "#/$defs/primitives/Hypothesis"
          }
        }
      },
      "attribute": {
        "title": "Attribute",
        "type": "object",
        "additionalProperties": false,
        "required": [
          "metric",
          "current",
          "baseline",
          "dimensions"
        ],
        "properties": {
          "metric": {
            "type": "string",
            "minLength": 1
          },
          "current": {
            "$ref": "#/$defs/primitives/Slice"
          },
          "baseline": {
            "$ref": "#/$defs/primitives/Slice"
          },
          "dimensions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "decomposition_method": {
            "type": "string",
            "default": "delta_share",
            "enum": [
              "delta_share"
            ]
          },
          "decomposition_limit": {
            "type": "integer",
            "minimum": 1,
            "default": 5
          }
        }
      },
      "diagnose": {
        "title": "Diagnose",
        "type": "object",
        "additionalProperties": false,
        "required": [
          "metric",
          "time_scope",
          "granularity",
          "strategy",
          "dimensions"
        ],
        "properties": {
          "metric": {
            "description": "Semantic metric identifier to diagnose. Diagnose runs against exactly one metric.",
            "type": "string",
            "minLength": 1
          },
          "time_scope": {
            "description": "Time range scanned by the internal detect step before follow-up diagnosis.",
            "$ref": "#/$defs/primitives/TimeScope"
          },
          "granularity": {
            "description": "Time bucket granularity used by the internal detect scan.",
            "type": "string",
            "enum": [
              "hour",
              "day",
              "week",
              "month",
              "quarter",
              "year"
            ]
          },
          "filter": {
            "description": "Optional AOI expression applied to both candidate detection and follow-up observe/compare/decompose steps.",
            "$ref": "#/$defs/primitives/Expression"
          },
          "scan_dimension": {
            "description": "Optional single dimension used only to split the internal detect scan into independent time series. Omit to scan the overall metric series.",
            "type": "string",
            "minLength": 1
          },
          "dimensions": {
            "description": "Non-empty attribution dimension list used after anomaly candidates are found. These dimensions drive follow-up decompose steps and are independent of scan_dimension.",
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "strategy": {
            "description": "Detection strategy passed to the internal detect step.",
            "type": "string",
            "enum": [
              "point_anomaly",
              "period_shift"
            ]
          },
          "sensitivity": {
            "description": "Detection sensitivity preset passed to the internal detect step. Defaults to aggressive.",
            "type": "string",
            "default": "aggressive",
            "enum": [
              "conservative",
              "balanced",
              "aggressive"
            ]
          },
          "candidate_limit": {
            "description": "Maximum number of anomaly candidates diagnosed end-to-end. This bounds follow-up candidates, not driver rows.",
            "type": "integer",
            "minimum": 1,
            "default": 3
          },
          "decomposition_limit": {
            "description": "Maximum number of driver rows returned per diagnosed candidate and attribution dimension.",
            "type": "integer",
            "minimum": 1,
            "default": 5
          }
        }
      }
    },
    "artifacts": {
      "Artifact": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifact_id"
        ],
        "properties": {
          "artifact_id": {
            "type": "string",
            "minLength": 1
          },
          "result": {
            "anyOf": [
              {
                "$ref": "#/$defs/artifacts/ScalarDeltaResult"
              },
              {
                "$ref": "#/$defs/artifacts/TimeSeriesDeltaResult"
              },
              {
                "$ref": "#/$defs/artifacts/SegmentedDeltaResult"
              },
              {
                "$ref": "#/$defs/artifacts/DeltaDecompositionResult"
              },
              {
                "$ref": "#/$defs/artifacts/AnomalyCandidatesResult"
              },
              {
                "$ref": "#/$defs/artifacts/AssociationResult"
              },
              {
                "$ref": "#/$defs/artifacts/HypothesisTestResult"
              },
              {
                "$ref": "#/$defs/artifacts/ForecastSeriesResult"
              }
            ]
          },
          "failure": {
            "$ref": "#/$defs/primitives/AnalysisFailure"
          }
        },
        "oneOf": [
          {
            "required": [
              "result"
            ],
            "not": {
              "required": [
                "failure"
              ]
            }
          },
          {
            "required": [
              "failure"
            ],
            "not": {
              "required": [
                "result"
              ]
            }
          }
        ]
      },
      "ArtifactEnvelope": {
        "type": "object",
        "required": [
          "artifact_id"
        ],
        "properties": {
          "artifact_id": {
            "type": "string",
            "minLength": 1
          },
          "failure": {
            "$ref": "#/$defs/primitives/AnalysisFailure"
          }
        },
        "additionalProperties": false
      },
      "MetricFrameArtifact": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifact_id",
          "artifact_family",
          "shape",
          "subject",
          "axes",
          "measures",
          "payload"
        ],
        "properties": {
          "artifact_id": {
            "type": "string",
            "minLength": 1
          },
          "artifact_family": {
            "const": "metric_frame"
          },
          "shape": {
            "type": "string",
            "enum": [
              "scalar",
              "time_series",
              "segmented",
              "panel"
            ]
          },
          "subject": {
            "$ref": "#/$defs/artifacts/MetricFrameSubject"
          },
          "axes": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/artifacts/MetricFrameAxis"
            }
          },
          "measures": {
            "type": "array",
            "minItems": 1,
            "maxItems": 1,
            "items": {
              "$ref": "#/$defs/artifacts/MetricFrameMeasure"
            }
          },
          "payload": {
            "$ref": "#/$defs/artifacts/MetricFramePayload"
          }
        }
      },
      "MetricFrameSubject": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "metric_ref",
          "time_scope",
          "scope"
        ],
        "properties": {
          "kind": {
            "const": "metric"
          },
          "metric_ref": {
            "type": "string",
            "minLength": 1
          },
          "time_scope": {
            "$ref": "#/$defs/primitives/TimeScope"
          },
          "scope": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "MetricFrameAxis": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind",
              "grain"
            ],
            "properties": {
              "kind": {
                "const": "time"
              },
              "grain": {
                "$ref": "#/$defs/primitives/TimeGranularity"
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind",
              "name"
            ],
            "properties": {
              "kind": {
                "const": "dimension"
              },
              "name": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        ]
      },
      "MetricFrameMeasure": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "value_type",
          "nullable"
        ],
        "properties": {
          "id": {
            "const": "value"
          },
          "value_type": {
            "const": "number"
          },
          "nullable": {
            "const": true
          },
          "unit": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          }
        }
      },
      "MetricFramePayload": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "series"
        ],
        "properties": {
          "series": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/artifacts/MetricFrameSeries"
            }
          }
        }
      },
      "MetricFrameSeries": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "keys",
          "points"
        ],
        "properties": {
          "keys": {
            "type": "object",
            "additionalProperties": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "number"
                },
                {
                  "type": "boolean"
                },
                {
                  "type": "null"
                }
              ]
            }
          },
          "points": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/artifacts/MetricFramePoint"
            }
          }
        }
      },
      "MetricFramePoint": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "value"
        ],
        "properties": {
          "window": {
            "$ref": "#/$defs/artifacts/MetricFrameWindow"
          },
          "value": {
            "$ref": "#/$defs/primitives/NumberOrNull"
          }
        }
      },
      "MetricFrameWindow": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "start",
          "end"
        ],
        "properties": {
          "start": {
            "$ref": "#/$defs/primitives/ISO8601"
          },
          "end": {
            "$ref": "#/$defs/primitives/ISO8601"
          }
        }
      },
      "ScalarDeltaResult": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "current_value",
          "baseline_value",
          "delta",
          "matched_time_scope"
        ],
        "properties": {
          "current_value": {
            "$ref": "#/$defs/primitives/NumberOrNull"
          },
          "baseline_value": {
            "$ref": "#/$defs/primitives/NumberOrNull"
          },
          "delta": {
            "$ref": "#/$defs/primitives/NumberOrNull"
          },
          "matched_time_scope": {
            "anyOf": [
              {
                "$ref": "#/$defs/primitives/TimeScope"
              },
              {
                "type": "null"
              }
            ]
          }
        }
      },
      "TimeSeriesDeltaResult": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "points",
          "matched_time_scope"
        ],
        "properties": {
          "points": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/artifacts/DeltaPoint"
            }
          },
          "matched_time_scope": {
            "anyOf": [
              {
                "$ref": "#/$defs/primitives/TimeScope"
              },
              {
                "type": "null"
              }
            ]
          }
        }
      },
      "SegmentedDeltaResult": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "rows",
          "matched_time_scope"
        ],
        "properties": {
          "rows": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/artifacts/SegmentedDeltaRow"
            }
          },
          "matched_time_scope": {
            "anyOf": [
              {
                "$ref": "#/$defs/primitives/TimeScope"
              },
              {
                "type": "null"
              }
            ]
          }
        }
      },
      "DeltaDecompositionResult": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "items"
        ],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/artifacts/DecompositionItem"
            }
          }
        }
      },
      "AnomalyCandidatesResult": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "items"
        ],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/artifacts/AnomalyCandidate"
            }
          }
        }
      },
      "AssociationResult": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "coefficient",
          "p_value",
          "n_pairs",
          "matched_time_scope"
        ],
        "properties": {
          "coefficient": {
            "type": "number",
            "minimum": -1,
            "maximum": 1
          },
          "p_value": {
            "anyOf": [
              {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              {
                "type": "null"
              }
            ]
          },
          "n_pairs": {
            "type": "integer",
            "minimum": 0
          },
          "matched_time_scope": {
            "anyOf": [
              {
                "$ref": "#/$defs/primitives/TimeScope"
              },
              {
                "type": "null"
              }
            ]
          }
        }
      },
      "HypothesisTestResult": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "statistic",
          "p_value",
          "decision",
          "assumption_notes"
        ],
        "properties": {
          "statistic": {
            "type": "number"
          },
          "p_value": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "decision": {
            "type": "object",
            "additionalProperties": false,
