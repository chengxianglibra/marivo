{
  "metric": "revenue",
  "time_scope": {
    "field": "event_time",
    "start": "2026-01-01T00:00:00Z",
    "end": "2026-02-01T00:00:00Z"
  },
  "granularity": "day",
  "filter": {
    "dialects": [
      {
        "dialect": "ANSI_SQL",
        "expression": "channel IN ('paid', 'organic')"
      }
    ]
  },
  "dimension": "channel",
  "strategy": "period_shift",
  "sensitivity": "balanced",
  "limit": 10
}
