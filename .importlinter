[importlinter]
root_package = marivo
exclude_type_checking_imports = true
include_external_packages = true

[importlinter:contract:contracts-isolation]
name = contracts/ must not import app internals
type = forbidden
source_modules =
    marivo.contracts
forbidden_modules =
    marivo.api
    marivo.storage
    marivo.evidence_engine
    marivo.adapters
    marivo.cli

[importlinter:contract:ports-isolation]
name = ports/ must not import app internals
type = forbidden
source_modules =
    marivo.ports
forbidden_modules =
    marivo.api
    marivo.storage
    marivo.evidence_engine
    marivo.adapters
    marivo.cli

[importlinter:contract:runtime-no-direct-core-orchestration]
name = runtime/ must not bypass service.py for core orchestration
type = forbidden
source_modules =
    marivo.runtime
forbidden_modules =
    marivo.evidence_engine
ignore_imports =
    marivo.runtime.semantic_ops -> marivo.evidence_engine.ref_boundary
    marivo.runtime.semantic.compile_step -> marivo.evidence_engine.ref_boundary
    marivo.runtime.session -> marivo.evidence_engine.context_view
    marivo.runtime.session -> marivo.evidence_engine.state_view
    marivo.runtime.intents.* -> marivo.evidence_engine.*

[importlinter:contract:core-no-io]
name = core/ must not import I/O or ports
type = forbidden
source_modules =
    marivo.core
forbidden_modules =
    marivo.api
    marivo.storage
    marivo.evidence_engine
    marivo.adapters
    marivo.cli
    marivo.ports

[importlinter:contract:surfaces-must-use-runtime]
name = api/ and cli/ must go through runtime
type = forbidden
source_modules =
    marivo.api
    marivo.cli
forbidden_modules =
    marivo.evidence_engine
ignore_imports =
    marivo.api.sessions -> marivo.runtime
    marivo.runtime.* -> marivo.evidence_engine.*
    marivo.runtime.semantic.* -> marivo.evidence_engine.*
    marivo.runtime.intents.* -> marivo.evidence_engine.*
    marivo.adapters.server.artifact_store -> marivo.evidence_engine.canonical_finding

[importlinter:contract:transports-mcp-no-api-internals]
name = transports/mcp/ must not import app/api/ internals
type = forbidden
source_modules =
    marivo.transports.mcp
forbidden_modules =
    marivo.api.endpoints

[importlinter:contract:profiles-do-not-import-runtime-factory]
name = profiles must not import the deleted runtime factory
type = forbidden
source_modules =
    marivo.profiles
forbidden_modules =
    marivo.runtime.factory

[importlinter:contract:no-app-service]
name = No module may import app.service or app.session.session_manager
type = forbidden
source_modules =
    marivo
forbidden_modules =
    marivo.service
    marivo.session.session_manager

[importlinter:contract:no-legacy-app-namespace]
name = No remaining app namespace imports
type = forbidden
source_modules =
    marivo
forbidden_modules =
    app
