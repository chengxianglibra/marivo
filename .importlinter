[importlinter]
root_package = marivo
exclude_type_checking_imports = true
include_external_packages = true

[importlinter:contract:contracts-isolation]
name = contracts/ must not import app internals
type = forbidden
source_modules =
    marivo.contracts
forbidden_modules =
    marivo.adapters
    marivo.transports.cli

[importlinter:contract:generated-contracts-isolation]
name = contracts/generated/ must not import runtime, adapters, or transports
type = forbidden
source_modules =
    marivo.contracts.generated
forbidden_modules =
    marivo.runtime
    marivo.adapters
    marivo.transports

[importlinter:contract:ports-isolation]
name = ports/ must not import app internals
type = forbidden
source_modules =
    marivo.ports
forbidden_modules =
    marivo.adapters
    marivo.transports.cli

[importlinter:contract:runtime-no-direct-core-orchestration]
name = runtime/ must not bypass service.py for core orchestration
type = forbidden
source_modules =
    marivo.runtime
forbidden_modules =
    marivo.core.orchestration

[importlinter:contract:core-no-io]
name = core/ must not import I/O or ports
type = forbidden
source_modules =
    marivo.core
forbidden_modules =
    marivo.adapters
    marivo.transports.cli
    marivo.ports

[importlinter:contract:surfaces-must-use-runtime]
name = transports/http/ and cli/ must go through runtime
type = forbidden
source_modules =
    marivo.transports.http
    marivo.transports.cli
forbidden_modules =
    marivo.core.orchestration
ignore_imports =
    marivo.transports.http.sessions -> marivo.runtime

[importlinter:contract:transports-mcp-no-api-internals]
name = transports/mcp/ must not import transports/http/ internals
type = forbidden
source_modules =
    marivo.transports.mcp
forbidden_modules =
    marivo.transports.http.endpoints

[importlinter:contract:profiles-do-not-import-runtime-factory]
name = profiles must not import the deleted runtime factory
type = forbidden
source_modules =
    marivo.profiles
forbidden_modules =
    marivo.runtime.factory

[importlinter:contract:no-app-service]
name = No module may import app.service or app.session.session_manager
type = forbidden
source_modules =
    marivo
forbidden_modules =
    marivo.service
    marivo.session.session_manager

[importlinter:contract:no-legacy-app-namespace]
name = No remaining app namespace imports
type = forbidden
source_modules =
    marivo
forbidden_modules =
    app

[importlinter:contract:runtime-uses-generated-contracts]
name = runtime/ must not import OSI/AOI contract models from transports/http/models
type = forbidden
source_modules =
    marivo.runtime
forbidden_modules =
    marivo.transports.http.models.osi
    marivo.transports.http.models.marivo_extensions
