[importlinter]
root_package = marivo
exclude_type_checking_imports = true
include_external_packages = true

[importlinter:contract:datasource-is-leaf]
name = datasource must not depend on semantic or analysis
type = forbidden
source_modules =
    marivo.datasource
forbidden_modules =
    marivo.semantic
    marivo.analysis

[importlinter:contract:semantic-does-not-import-analysis]
name = semantic must not depend on analysis
type = forbidden
source_modules =
    marivo.semantic
forbidden_modules =
    marivo.analysis

[importlinter:contract:analysis-evidence-isolation]
name = analysis.evidence must not import analysis internals beyond evidence + frames + lineage + refs + errors + followups + session.persistence
type = forbidden
source_modules =
    marivo.analysis.evidence
forbidden_modules =
    marivo.analysis.intents
    marivo.analysis.executor
    marivo.analysis.calendar
    marivo.analysis.windows
    marivo.analysis.datasources
    marivo.analysis.profiles
    marivo.analysis.policies

[importlinter:contract:live-is-neutral-leaf]
name = introspection.live must not depend on datasource, semantic, or analysis
type = forbidden
source_modules =
    marivo.introspection.live
forbidden_modules =
    marivo.datasource
    marivo.semantic
    marivo.analysis
    marivo._authoring
    marivo._boundaries

[importlinter:contract:authoring-is-private-domain-kernel]
name = _authoring must not depend on surfaces or boundary protocols
type = forbidden
source_modules =
    marivo._authoring
forbidden_modules =
    marivo.datasource
    marivo.semantic
    marivo.analysis
    marivo._boundaries

[importlinter:contract:boundaries-are-surface-neutral]
name = _boundaries must not depend on surfaces or authoring
type = forbidden
source_modules =
    marivo._boundaries
forbidden_modules =
    marivo.datasource
    marivo.semantic
    marivo.analysis
    marivo._authoring
