{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marivo.dev/schemas/osi-marivo/0.1.0/osi-marivo.schema.json",
  "title": "OSI Core Metadata Specification with MARIVO Vendor Extensions",
  "description": "JSON Schema for validating OSI 0.1.1 semantic model definitions with the MARIVO vendor namespace and fixed MARIVO custom extension payload schemas.",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "const": "0.1.1",
      "description": "OSI specification version"
    },
    "dialects": {
      "type": "array",
      "description": "Supported expression language dialects (enumeration definition)",
      "items": {
        "$ref": "#/$defs/Dialect"
      }
    },
    "vendors": {
      "type": "array",
      "description": "Supported vendors for custom extensions (MARIVO only)",
      "items": {
        "$ref": "#/$defs/Vendor"
      }
    },
    "semantic_model": {
      "type": "array",
      "description": "Collection of semantic model definitions",
      "items": {
        "$ref": "#/$defs/SemanticModel"
      }
    }
  },
  "required": [
    "version",
    "semantic_model"
  ],
  "additionalProperties": false,
  "$defs": {
    "Dialect": {
      "type": "string",
      "enum": [
        "ANSI_SQL",
        "SNOWFLAKE",
        "MDX",
        "TABLEAU",
        "DATABRICKS",
        "TRINO"
      ],
      "description": "Supported SQL and expression language dialects"
    },
    "Vendor": {
      "type": "string",
      "enum": [
        "MARIVO"
      ],
      "description": "Supported vendor for custom extensions."
    },
    "TimeGranularity": {
      "type": "string",
      "enum": [
        "hour",
        "day",
        "week",
        "month",
        "quarter",
        "year"
      ],
      "description": "Supported time granularities, ordered from finest to coarsest."
    },
    "AggregationSemantics": {
      "oneOf": [
        {
          "type": "object",
          "description": "Additive quantity — values sum across groups. No component refs needed.",
          "properties": {
            "type": { "type": "string", "const": "sum" }
          },
          "required": ["type"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "description": "Proportion/rate metric. Requires numerator and denominator component specs.",
          "properties": {
            "type": { "type": "string", "const": "ratio" },
            "numerator": { "$ref": "#/$defs/ComponentSpec" },
            "denominator": { "$ref": "#/$defs/ComponentSpec" }
          },
          "required": ["type", "numerator", "denominator"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "description": "Ratio-of-sums metric. Requires numerator and weight component specs.",
          "properties": {
            "type": { "type": "string", "const": "weighted_average" },
            "numerator": { "$ref": "#/$defs/ComponentSpec" },
            "weight": { "$ref": "#/$defs/ComponentSpec" }
          },
          "required": ["type", "numerator", "weight"],
          "additionalProperties": false
        }
      ],
      "description": "Discriminated union of aggregation semantics variants. Each variant is an object with a 'type' field as discriminator."
    },
    "AIContext": {
      "description": "Additional context for AI tools",
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "properties": {
            "instructions": {
              "type": "string",
              "description": "Instructions for AI on how to use this entity"
            },
            "synonyms": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Alternative names and terms"
            },
            "examples": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Sample questions or use cases"
            }
          },
          "additionalProperties": true
        }
      ]
    },
    "CustomExtension": {
      "type": "object",
      "description": "Vendor-specific attributes for extensibility",
      "properties": {
        "vendor_name": {
          "$ref": "#/$defs/Vendor"
        },
        "data": {
          "type": "object",
          "description": "Vendor-specific data payload"
        }
      },
      "required": [
        "vendor_name",
        "data"
      ],
      "additionalProperties": false
    },
    "DialectExpression": {
      "type": "object",
      "description": "Expression in a specific dialect",
      "properties": {
        "dialect": {
          "$ref": "#/$defs/Dialect"
        },
        "expression": {
          "type": "string",
          "description": "SQL or dialect-specific expression"
        }
      },
      "required": [
        "dialect",
        "expression"
      ],
      "additionalProperties": false
    },
    "Expression": {
      "type": "object",
      "description": "Expression definition with multi-dialect support",
      "properties": {
        "dialects": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/DialectExpression"
          },
          "minItems": 1
        }
      },
      "required": [
        "dialects"
      ],
      "additionalProperties": false
    },
    "Dimension": {
      "type": "object",
      "description": "Dimension metadata",
      "properties": {
        "is_time": {
          "type": "boolean",
          "description": "Indicates if this is a time-based dimension for temporal filtering"
        }
      },
      "additionalProperties": false
    },
    "Field": {
      "type": "object",
      "description": "Row-level attribute for grouping, filtering, and metric expressions",
      "properties": {
        "name": {
          "type": "string",
          "description": "Unique identifier for the field within the dataset"
        },
        "expression": {
          "$ref": "#/$defs/Expression"
        },
        "dimension": {
          "$ref": "#/$defs/Dimension"
        },
        "label": {
          "type": "string",
          "description": "Label for categorization"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description"
        },
        "ai_context": {
          "$ref": "#/$defs/AIContext"
        },
        "custom_extensions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/MarivoFieldCustomExtension"
          },
          "maxItems": 1,
          "description": "MARIVO field custom extension payload. Required for time fields; not allowed for non-time fields."
        }
      },
      "required": [
        "name",
        "expression"
      ],
      "allOf": [
        {
          "if": {
            "required": [
              "dimension"
            ],
            "properties": {
              "dimension": {
                "required": [
                  "is_time"
                ],
                "properties": {
                  "is_time": {
                    "const": true
                  }
                }
              }
            }
          },
          "then": {
            "required": [
              "custom_extensions"
            ],
            "properties": {
              "custom_extensions": {
                "minItems": 1,
                "maxItems": 1
              }
            }
          },
          "else": {
            "properties": {
              "custom_extensions": {
                "maxItems": 0
              }
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "Dataset": {
      "type": "object",
      "description": "Logical dataset representing a business entity (fact or dimension table)",
      "properties": {
        "name": {
          "type": "string",
          "description": "Unique identifier for the dataset"
        },
        "source": {
          "type": "string",
          "description": "Reference to underlying physical table or view as a relation FQN (schema.table or catalog.schema.table)"
        },
        "primary_key": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Primary key columns (single or composite)"
        },
        "unique_keys": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "description": "Array of unique key definitions (each can be single or composite)"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description"
        },
        "ai_context": {
          "$ref": "#/$defs/AIContext"
        },
        "fields": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Field"
          }
        },
        "custom_extensions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/MarivoDatasetCustomExtension"
          }
        }
      },
      "required": [
        "name",
        "source"
      ],
      "additionalProperties": false
    },
    "Relationship": {
      "type": "object",
      "description": "Foreign key relationship between datasets",
      "properties": {
        "name": {
          "type": "string",
          "description": "Unique identifier for the relationship"
        },
        "from": {
          "type": "string",
          "description": "Dataset on the many side of the relationship"
        },
        "to": {
          "type": "string",
          "description": "Dataset on the one side of the relationship"
        },
        "from_columns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "description": "Foreign key columns in the 'from' dataset"
        },
        "to_columns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "description": "Primary/unique key columns in the 'to' dataset"
        },
        "ai_context": {
          "$ref": "#/$defs/AIContext"
        },
        "custom_extensions": {
          "type": "array",
          "maxItems": 0,
          "description": "No MARIVO custom extensions are defined for relationships."
        }
      },
      "required": [
        "name",
        "from",
        "to",
        "from_columns",
        "to_columns"
      ],
      "additionalProperties": false
    },
    "Metric": {
      "type": "object",
      "description": "Quantitative measure defined on business data",
      "properties": {
        "name": {
          "type": "string",
          "description": "Unique identifier for the metric"
        },
        "expression": {
          "$ref": "#/$defs/Expression"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of what the metric measures"
        },
        "ai_context": {
          "$ref": "#/$defs/AIContext"
        },
        "custom_extensions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/MarivoMetricCustomExtension"
          }
        }
      },
      "required": [
        "name",
        "expression"
      ],
      "additionalProperties": false
    },
    "SemanticModel": {
      "type": "object",
      "description": "Top-level container representing a complete semantic model",
      "properties": {
        "name": {
          "type": "string",
          "description": "Unique identifier for the semantic model"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description"
        },
        "ai_context": {
          "$ref": "#/$defs/AIContext"
        },
        "datasets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Dataset"
          },
          "minItems": 1,
          "description": "Collection of logical datasets"
        },
        "relationships": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Relationship"
          },
          "description": "Defines how datasets are connected"
        },
        "metrics": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Metric"
          },
          "description": "Quantifiable measures spanning datasets"
        },
        "custom_extensions": {
          "type": "array",
          "maxItems": 0,
          "description": "No MARIVO custom extensions are defined for semantic models."
        }
      },
      "required": [
        "name",
        "datasets"
      ],
      "additionalProperties": false
    },
    "MarivoDatasetExtension": {
      "type": "object",
      "description": "MARIVO extension payload for Dataset.",
      "properties": {
        "datasource_id": {
          "type": "string",
          "minLength": 1,
          "description": "Marivo datasource reference used for routing, readiness, and schema resolution."
        }
      },
      "required": [
        "datasource_id"
      ],
      "additionalProperties": false
    },
    "MarivoFieldExtension": {
      "type": "object",
      "description": "MARIVO extension payload for Field.",
      "properties": {
        "support_min_granularity": {
          "$ref": "#/$defs/TimeGranularity",
          "description": "Finest time granularity supported by this time field. Requests must use this granularity or a coarser one."
        },
        "data_type": {
          "type": "string",
          "enum": ["date", "timestamp", "string", "integer"],
          "description": "Physical SQL data type of this time field column. Required for all time fields. Marivo uses this to determine how to generate time predicates and analysis expressions."
        },
        "format": {
          "type": "string",
          "description": "Temporal format pattern for string-type and integer-type time fields. Required when data_type is 'string' or 'integer'. Examples: 'yyyymmdd', 'yyyy-mm-dd', 'yyyymmddhh', 'hh', 'epoch_seconds'. Optional for date/timestamp types."
        },
        "required_prefix": {
          "type": "string",
          "description": "Field name of the date-format time field that provides date context for this hour-only field. Required when format is 'hh' or 'h'. Must reference a time field on the same dataset. Not allowed on fields with complete date or timestamp formats."
        }
      },
      "required": [
        "support_min_granularity",
        "data_type"
      ],
      "additionalProperties": false
    },
    "MetricComponentRef": {
      "type": "object",
      "description": "Structured reference to a semantic metric for decomposition component definitions.",
      "properties": {
        "metric": {
          "type": "string",
          "minLength": 1,
          "description": "Reference to a published semantic metric, e.g. 'metric.converted_users'"
        }
      },
      "required": [
        "metric"
      ],
      "additionalProperties": false
    },
    "ExpressionComponent": {
      "type": "object",
      "description": "SQL expression for computing a decomposition component value directly, without referencing another metric.",
      "properties": {
        "expression": {
          "type": "string",
          "minLength": 1,
          "description": "SQL expression for computing the component value"
        }
      },
      "required": [
        "expression"
      ],
      "additionalProperties": false
    },
    "ComponentSpec": {
      "oneOf": [
        { "$ref": "#/$defs/MetricComponentRef" },
        { "$ref": "#/$defs/ExpressionComponent" }
      ],
      "description": "Component specification: either a reference to an existing semantic metric or an inline SQL expression."
    },
    "MarivoMetricExtension": {
      "type": "object",
      "description": "MARIVO extension payload for Metric.",
      "properties": {
        "aggregation_semantics": {
          "$ref": "#/$defs/AggregationSemantics",
          "default": { "type": "sum" },
          "description": "Discriminated union of aggregation semantics. Determines inferential summary mode, statistical test method, and decomposition strategy. sum: additive quantity, delta_share decomposition. ratio: proportion/rate, requires numerator+denominator. weighted_average: ratio-of-sums, requires numerator+weight."
        }
      },
      "additionalProperties": true
    },
    "MarivoDatasetCustomExtension": {
      "type": "object",
      "description": "MARIVO custom extension for Dataset.",
      "properties": {
        "vendor_name": {
          "const": "MARIVO"
        },
        "data": {
          "$ref": "#/$defs/MarivoDatasetExtension"
        }
      },
      "required": [
        "vendor_name",
        "data"
      ],
      "additionalProperties": false
    },
    "MarivoFieldCustomExtension": {
      "type": "object",
      "description": "MARIVO custom extension for Field.",
      "properties": {
        "vendor_name": {
          "const": "MARIVO"
        },
        "data": {
          "$ref": "#/$defs/MarivoFieldExtension"
        }
      },
      "required": [
        "vendor_name",
        "data"
      ],
      "additionalProperties": false
    },
    "MarivoMetricCustomExtension": {
      "type": "object",
      "description": "MARIVO custom extension for Metric.",
      "properties": {
        "vendor_name": {
          "const": "MARIVO"
        },
        "data": {
          "$ref": "#/$defs/MarivoMetricExtension"
        }
      },
      "required": [
        "vendor_name",
        "data"
      ],
      "additionalProperties": false
    }
  },
  "$comment": "Generated from https://github.com/open-semantic-interchange/OSI/blob/main/core-spec/osi-schema.json. MARIVO-specific payload schemas describe the object stored in custom_extensions[].data."
}
