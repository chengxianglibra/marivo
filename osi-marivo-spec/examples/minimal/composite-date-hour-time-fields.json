{
  "version": "0.1.1",
  "dialects": ["ANSI_SQL"],
  "semantic_model": [
    {
      "name": "query_logs",
      "datasets": [
        {
          "name": "query_logs",
          "source": "iceberg.analytics.query_logs",
          "fields": [
            {
              "name": "log_date",
              "expression": { "dialects": [{ "dialect": "ANSI_SQL", "expression": "log_date" }] },
              "dimension": { "is_time": true },
              "custom_extensions": [
                {
                  "vendor_name": "MARIVO",
                  "data": {
                    "support_min_granularity": "day",
                    "data_type": "string",
                    "format": "yyyymmdd"
                  }
                }
              ]
            },
            {
              "name": "log_hour",
              "expression": { "dialects": [{ "dialect": "ANSI_SQL", "expression": "log_hour" }] },
              "dimension": { "is_time": true },
              "custom_extensions": [
                {
                  "vendor_name": "MARIVO",
                  "data": {
                    "support_min_granularity": "hour",
                    "data_type": "string",
                    "format": "hh",
                    "required_prefix": "log_date"
                  }
                }
              ]
            },
            {
              "name": "region",
              "expression": { "dialects": [{ "dialect": "ANSI_SQL", "expression": "region" }] },
              "dimension": { "is_time": false }
            }
          ],
          "custom_extensions": [
            {
              "vendor_name": "MARIVO",
              "data": { "datasource_id": "ds_trino_prod" }
            }
          ]
        }
      ],
      "metrics": [
        {
          "name": "query_count",
          "expression": { "dialects": [{ "dialect": "ANSI_SQL", "expression": "COUNT(*)" }] },
          "custom_extensions": [
            {
              "vendor_name": "MARIVO",
              "data": { "additive_dimensions": ["region"], "aggregation_semantics": "sum" }
            }
          ]
        }
      ]
    }
  ]
}
