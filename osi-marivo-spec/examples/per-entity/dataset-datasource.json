{
  "version": "0.1.1",
  "semantic_model": [
    {
      "name": "multi_source",
      "datasets": [
        {
          "name": "clickstream",
          "source": "events.public.page_views",
          "fields": [
            {
              "name": "event_ts",
              "expression": { "dialects": [{ "dialect": "ANSI_SQL", "expression": "event_timestamp" }] },
              "dimension": { "is_time": true },
              "custom_extensions": [
                {
                  "vendor_name": "MARIVO",
                  "data": { "support_min_granularity": "hour", "data_type": "timestamp" }
                }
              ]
            },
            {
              "name": "user_id",
              "expression": { "dialects": [{ "dialect": "ANSI_SQL", "expression": "user_id" }] }
            }
          ],
          "custom_extensions": [
            {
              "vendor_name": "MARIVO",
              "data": { "datasource_id": "ds_clickhouse_prod" }
            }
          ]
        }
      ]
    }
  ]
}
